# ==============================================================================
# FNLLA ENVIRONMENT TEMPLATE
# Copyright (c) 2026 TechAyo LTD (techayo.co.uk). All rights reserved.
# Produced, maintained and distributed by TechAyo LTD.
# This template defines the baseline local environment contract for FNLLA.
# FNLLA uses MySQL and the vendored FNLLA Runtime runtime in the official stack.
# ==============================================================================

APP_ENV=development
APP_DEBUG=true
APP_URL=
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_LOG_PATH=

FNLLA_WEB_ENFORCE=true
FNLLA_WEB_AUTO_SYNC=true
FNLLA_WEB_SYNC_INTERVAL_SECONDS=900
FNLLA_WEB_SYNC_SCRIPT=scripts/sync-fnlla-runtime.ps1
FNLLA_WEB_STATE_PATH=framework/fnlla-runtime-guard.json

FRAMEWORK_UPDATE_UI_ENABLED=true
FRAMEWORK_UPDATE_UI_LOCAL_ONLY=true
FRAMEWORK_UPDATE_UI_APPLY_ENABLED=true
FRAMEWORK_UPDATE_GITHUB_ENABLED=true
FRAMEWORK_UPDATE_GITHUB_REPOSITORY=fnlla/php
FRAMEWORK_UPDATE_GITHUB_API_BASE_URL=https://api.github.com
FRAMEWORK_UPDATE_GITHUB_TIMEOUT_SECONDS=20
FRAMEWORK_UPDATE_DOWNLOAD_CACHE_PATH=framework/updates/fnlla
FRAMEWORK_UPDATE_SOURCE_PATH=
TRUSTED_PROXIES=

MAINTENANCE_MODE_ENABLED=false
MAINTENANCE_ACCESS_USERNAME=
MAINTENANCE_ACCESS_PASSWORD=
MAINTENANCE_SETUP_UI_ENABLED=true
MAINTENANCE_SETUP_UI_LOCAL_ONLY=true
MAINTENANCE_ACCESS_TTL_MINUTES=10
MAINTENANCE_ACCESS_MAX_ATTEMPTS=5
MAINTENANCE_ACCESS_WINDOW_MINUTES=15
MAINTENANCE_ACCESS_LOCKOUT_MINUTES=15

DEVELOPER_ACCESS_ENABLED=true
DEVELOPER_ACCESS_PATH=
DEVELOPER_ACCESS_PASSWORD=
DEVELOPER_ACCESS_SETUP_UI_ENABLED=true
DEVELOPER_ACCESS_SETUP_UI_LOCAL_ONLY=true
DEVELOPER_ACCESS_TTL_MINUTES=120
DEVELOPER_ACCESS_MAX_ATTEMPTS=5
DEVELOPER_ACCESS_WINDOW_MINUTES=15
DEVELOPER_ACCESS_LOCKOUT_MINUTES=15
DEVELOPER_OPERATIONS_NAV_MODE=hidden

SESSION_NAME=fnlla_session
SESSION_LIFETIME_MINUTES=120
SESSION_ROTATE_AFTER_MINUTES=30
SESSION_SECURE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=Lax
SESSION_STRICT_MODE=true
SESSION_USE_ONLY_COOKIES=true

CSRF_ROTATE_AFTER_MINUTES=120

DB_DATABASE=fnlla
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_MIGRATIONS_TABLE=migrations

MAIL_MAILER=log
MAIL_LOG_PATH=mail
MAIL_FROM_ADDRESS=no-reply@example.com
CONTACT_NOTIFICATION_EMAIL=team@example.com

QUEUE_PATH=framework/queue

AUTH_SESSION_KEY=auth.user_id
AUTH_USERS_TABLE=users
AUTH_USERS_KEY=id
AUTH_USERS_IDENTITY=email
AUTH_USERS_PASSWORD=password
