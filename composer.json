{
    "name": "techayoDEV/fnlla-php",
    "description": "Open-source server-rendered PHP framework by TechAyo LTD for FNLLA Web based productions.",
    "type": "project",
    "license": "MIT",
    "homepage": "https://techayo.co.uk",
    "authors": [
        {
            "name": "TechAyo LTD",
            "homepage": "https://techayo.co.uk",
            "role": "Producer, maintainer and distributor"
        }
    ],
    "support": {
        "issues": "https://github.com/techayoDEV/fnlla-php/issues",
        "source": "https://github.com/techayoDEV/fnlla-php"
    },
    "require": {
        "php": "^8.3"
    },
    "autoload": {
        "psr-4": {
            "Fnlla\\Php\\": "src/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "scripts": {
        "console": "@php fnlla",
        "test": "@php scripts/test.php",
        "lint": [
            "@php scripts/lint.php",
            "@php scripts/validate-fnlla-web.php",
            "@php scripts/validate-version-manifest.php"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
