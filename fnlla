use Fnlla\Php\Console\Commands\CacheClearCommand;
use Fnlla\Php\Console\Commands\FnllaUiSyncCommand;
use Fnlla\Php\Console\Commands\FnllaUiValidateCommand;
use Fnlla\Php\Console\Commands\MakeCommandCommand;
use Fnlla\Php\Console\Commands\MakeControllerCommand;
use Fnlla\Php\Console\Commands\MakeFactoryCommand;
use Fnlla\Php\Console\Commands\MakeMigrationCommand;
use Fnlla\Php\Console\Commands\MakeMiddlewareCommand;
use Fnlla\Php\Console\Commands\MakeProjectCommand;
use Fnlla\Php\Console\Commands\MakeSeederCommand;
use Fnlla\Php\Console\Commands\MigrateCommand;
use Fnlla\Php\Console\Commands\MigrateRollbackCommand;
use Fnlla\Php\Console\Commands\MigrateStatusCommand;
use Fnlla\Php\Console\Commands\QueueWorkCommand;
use Fnlla\Php\Console\Commands\RouteListCommand;
use Fnlla\Php\Console\Commands\ScheduleRunCommand;
use Fnlla\Php\Console\Commands\SeedCommand;
use Fnlla\Php\Console\Commands\VersionStatusCommand;
use Fnlla\Php\Console\Commands\VersionSyncCommand;

/*
Guard bypass note:
- the dedicated FNLLA UI repair commands must stay callable even when the guard
  itself is blocking normal bootstrap because of a UI contract violation
- this keeps the repository recoverable without editing bootstrap files by hand
*/
if (in_array($_SERVER["argv"][1] ?? "", ["fnlla-ui:sync", "fnlla-ui:validate", "version:status", "version:sync"], true) && !defined("FNLLA_UI_SKIP_AUTO_GUARD")) {
    define("FNLLA_UI_SKIP_AUTO_GUARD", true);
}

$container = require __DIR__ . DIRECTORY_SEPARATOR . "bootstrap" . DIRECTORY_SEPARATOR . "console.php";

$console = $container->make(\Fnlla\Php\Console\Application::class);
$console->register(CacheClearCommand::class);
$console->register(FnllaUiSyncCommand::class);
$console->register(FnllaUiValidateCommand::class);
$console->register(SeedCommand::class);
$console->register(MigrateRollbackCommand::class);
$console->register(MigrateCommand::class);
$console->register(MigrateStatusCommand::class);
$console->register(MakeCommandCommand::class);
$console->register(MakeControllerCommand::class);
$console->register(MakeFactoryCommand::class);
$console->register(MakeMigrationCommand::class);
$console->register(MakeMiddlewareCommand::class);
$console->register(MakeProjectCommand::class);
$console->register(MakeSeederCommand::class);
$console->register(QueueWorkCommand::class);
$console->register(RouteListCommand::class);
$console->register(ScheduleRunCommand::class);
$console->register(VersionStatusCommand::class);
$console->register(VersionSyncCommand::class);

exit($console->run($_SERVER["argv"] ?? []));
